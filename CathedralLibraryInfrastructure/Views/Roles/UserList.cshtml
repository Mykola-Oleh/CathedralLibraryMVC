@using Microsoft.AspNetCore.Identity
@model IEnumerable<CathedralLibraryDomain.Model.User>

@{
    ViewData["Title"] = "Список користувачів";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Керування користувачами</h2>
    <a class="btn btn-outline-secondary" asp-action="Index">Назад до списку ролей</a>
</div>

<table class="table table-hover border">
    <thead class="table-dark">
        <tr>
            <th>Email</th>
            <th>Ім'я та Прізвище</th>
            <th>Рік народження</th>
            <th class="text-end">Дії</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Email</td>
                <td>@user.First_name @user.Last_name</td>
                <td>@user.Year</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-userid="@user.Id">
                        Права доступу
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>