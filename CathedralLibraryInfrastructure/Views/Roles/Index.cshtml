@using Microsoft.AspNetCore.Identity
@model IEnumerable<IdentityRole>

@{
    ViewData["Title"] = "Список ролей";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Список ролей системи</h2>
    <a class="btn btn-success" asp-action="Create">Додати нову роль</a>
</div>

<table class="table table-hover border">
    <thead class="table-light">
        <tr>
            <th>ID Ролі</th>
            <th>Назва</th>
            <th class="text-end">Дії</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var role in Model)
        {
            <tr>
                <td class="text-muted small">@role.Id</td>
                <td><span class="badge bg-info text-dark">@role.Name</span></td>
                <td class="text-end">
                    <form asp-action="Delete" asp-route-id="@role.Id" method="post">
                        <button type="submit" class="btn btn-outline-danger btn-sm"
                                onclick="return confirm('Ви впевнені, що хочете видалити цю роль?')">
                            Видалити
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-3">
    <a class="btn btn-secondary" asp-action="UserList">Керувати ролями користувачів</a>
</div>