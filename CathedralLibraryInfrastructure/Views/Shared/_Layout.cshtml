<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cathedral Library</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap_sandstone.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
            <div class="container">

                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    📚 Library
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">

                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Головна</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Publications" asp-action="Index">Видання</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Readers" asp-action="Index">Читачі</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Requests" asp-action="Index">Запити</a>
                        </li>

                        @if (User.IsInRole("admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Roles" asp-action="Index">Ролі</a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center">

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item me-2">
                                <span class="navbar-text">
                                    👤 @User.Identity.Name
                                </span>
                            </li>

                            <li class="nav-item">
                                <form method="post" asp-controller="Account" asp-action="Logout">
                                    <button class="btn btn-outline-light btn-sm">
                                        Вихід
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-light btn-sm me-2" asp-controller="Account" asp-action="Login">
                                    Вхід
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-light btn-sm" asp-controller="Account" asp-action="Register">
                                    Реєстрація
                                </a>
                            </li>
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <main class="flex-fill">
        <div class="container py-4">
            @RenderBody()
        </div>
    </main>

    <footer class="bg-light border-top mt-auto">
        <div class="container py-3 text-center text-muted">
            &copy; 2026 - Cathedral Library |
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>