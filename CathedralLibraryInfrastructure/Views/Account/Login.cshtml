@model CathedralLibraryInfrastructure.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Вхід";
}

<div class="row justify-content-center">
    <div class="col-md-4">
        <h2 class="text-center">Вхід в систему</h2>
        <hr />
        <form method="post" asp-controller="Account" asp-action="Login" asp-route-returnurl="@Model.ReturnUrl">
            <div asp-validation-summary="All" class="text-danger"></div>


            <div class="form-group mb-3">
                <label asp-for="Email" class="control-label font-weight-bold"></label>
                <input asp-for="Email" class="form-control" placeholder="example@knu.ua" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Password" class="control-label font-weight-bold">Пароль</label>
                <input asp-for="Password" class="form-control" type="password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-group mb-3 form-check">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label">Запам'ятати мене?</label>
            </div>

            <div class="d-grid gap-2">
                <input type="submit" value="Увійти" class="btn btn-primary" />
            </div>
        </form>

        <div class="mt-3 text-center">
            <p>Ще не маєте акаунту? <a asp-action="Register">Зареєструватися</a></p>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}